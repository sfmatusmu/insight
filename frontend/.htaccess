Options -Indexes

<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # Redirigir siempre a HTTPS (Opcional pero muy recomendado para prod)
    # RewriteCond %{HTTPS} off
    # RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # Quitar extensiones .html de las URLs visualizadas en la barra
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^([^\.]+)$ $1.html [NC,L]

    # Prevenir acceso directo a componentes de assets si es necesario (ej: denegar listar JS)
    RewriteRule ^assets/(.*)$ assets/$1 [L]
</IfModule>

<IfModule mod_headers.c>
    # Reforzar seguridad de Headers a nivel de Apache
    Header set X-XSS-Protection "1; mode=block"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header set X-Content-Type-Options "nosniff"
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
</IfModule>

# Habilitar compresión GZIP
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript
</IfModule>
